{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dankblossomapp",
  "compatibility_date": "2026-03-26",
  "main": "./worker.js",
  "observability": {
    "enabled": true
  },
  "routes": [
    { "pattern": "dankblossom.app/*", "zone_name": "dankblossom.app" }
  ],
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}

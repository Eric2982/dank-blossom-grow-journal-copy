<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <!--
    INTERNET is required for the web app and for the Play Integrity token
    request to reach Google Play servers.
  -->
  <uses-permission android:name="android.permission.INTERNET" />

  <!--
    Android 11+ package visibility: the Play Integrity API needs to query
    the Google Play Store (com.android.vending) to obtain an integrity token.
  -->
  <queries>
    <package android:name="com.android.vending" />
  </queries>

  <application>

    <activity
      android:name="com.dankblossom.MainActivity"
      android:exported="true"
      android:launchMode="singleTask"
      android:windowSoftInputMode="adjustResize">

      <!-- App entry-point -->
      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>

      <!--
        Android App Links for dankblossom.app.
        android:autoVerify="true" triggers automatic verification against the
        /.well-known/assetlinks.json file on the domain so that deep-links
        open directly in the app rather than the browser.
      -->
      <intent-filter android:autoVerify="true">
        <action android:name="android.intent.action.VIEW" />
        <category android:name="android.intent.category.DEFAULT" />
        <category android:name="android.intent.category.BROWSABLE" />
        <data android:scheme="http" android:host="dankblossom.app" />
        <data android:scheme="https" android:host="dankblossom.app" />
      </intent-filter>

    </activity>

    <meta-data
      android:name="asset_statements"
      android:resource="@string/asset_statements" />

  </application>
</manifest>

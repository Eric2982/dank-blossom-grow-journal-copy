<manifest xmlns:android="http://schemas.android.com/apk/res/android">

  <!--
    INTERNET is required for the web app and for the Play Integrity token
    request to reach Google Play servers.
  -->
  <uses-permission android:name="android.permission.INTERNET" />

  <!--
    Android 11+ package visibility: the Play Integrity API needs to query
    the Google Play Store (com.android.vending) to obtain an integrity token.
  -->
  <queries>
    <package android:name="com.android.vending" />
  </queries>

  <application>

    <!-- ============================================================
         Package: com.base69be6d60d8aa3924e66d8e69.app
         Activity: com.wix.MainActivity
         ============================================================ -->
    <activity
        android:name="com.wix.MainActivity"
        android:exported="true">

      <!-- Domain: dankblossom.app -->
      <intent-filter android:autoVerify="true">
        <action android:name="android.intent.action.VIEW" />
        <category android:name="android.intent.category.DEFAULT" />
        <category android:name="android.intent.category.BROWSABLE" />
        <!-- http delegates to https; do not add other schemes -->
        <data android:scheme="http" />
        <data android:scheme="https" />
        <data android:host="dankblossom.app" />
        <data android:host="*.dankblossom.app" />
      </intent-filter>

      <!-- Domain: archetypal-grow-wise-log.base44.app -->
